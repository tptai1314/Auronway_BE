{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/[...all].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all].js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/[...all].js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    }
  ]
}
